---
import Base from '../layouts/Base.astro';
import PostList from '../components/PostList.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<Base title="Nicolás Kriman">
  <h1>Nicolás Kriman</h1>
  <p class="intro">
    AI lead at Alpaca, a YC-backed brokerage-infrastructure company. I build agentic
    systems for developer productivity: coding agents, evals, harness engineering.
    Before this, first COO and later VP of Data at a LatAm private credit firm.
  </p>
  <div class="section-label">Writing</div>
  <PostList posts={posts} />
</Base>
<style>
  .intro { max-width: var(--width-prose); }
</style>
