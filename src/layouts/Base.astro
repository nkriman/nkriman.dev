---
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/500.css';
import '@fontsource/space-grotesk/600.css';
import '@fontsource/space-grotesk/700.css';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '@fontsource/ibm-plex-mono/600.css';

interface Props {
  title: string;
  description?: string;
  prose?: boolean;
}
const { title, description = 'Notes on building with AI.', prose = false } = Astro.props;
const onWriting = Astro.url.pathname.startsWith('/blog');
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={Astro.url} />
  </head>
  <body>
    <div class="frame">
      <header class="site">
        <a class="mark" href="/" aria-label="Nicolás Kriman — home">nk<span class="cursor"></span></a>
        <nav>
          <a href="/blog" class:list={[{ active: onWriting }]}>Writing</a>
          <a href="https://github.com/nkriman">GitHub</a>
          <a href="https://www.linkedin.com/in/nkriman/">LinkedIn</a>
        </nav>
      </header>
      <main class:list={[{ 'prose-page': prose }]}>
        <slot />
      </main>
      <footer class="site">
        <div class="id">Nicolás Kriman</div>
        <nav>
          <a href="https://github.com/nkriman">GitHub</a>
          <a href="https://www.linkedin.com/in/nkriman/">LinkedIn</a>
        </nav>
      </footer>
    </div>
  </body>
</html>
<style is:global>
  @import '../styles/global.css';
</style>
